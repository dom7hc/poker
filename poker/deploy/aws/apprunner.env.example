# Copy this file to deploy/aws/apprunner.env and edit values.

AWS_REGION=us-east-1
ECR_REPOSITORY=poker-console
APP_RUNNER_SERVICE_NAME=poker-console

# App Runner instance sizing
APP_RUNNER_CPU=1 vCPU
APP_RUNNER_MEMORY=2 GB

# Runtime game settings passed to the container
PLAYER_COUNT=4
MATCH_HANDS=5

# Security: required unless ALLOW_NO_AUTH=true
# Format: username:password
WEB_CREDENTIALS=changeme:replace-this-password
ALLOW_NO_AUTH=false

# Optional advanced settings
AUTO_DEPLOYMENTS_ENABLED=true
WAIT_FOR_RUNNING=true

# CloudWatch Logs retention for set_log_retention.sh
LOG_RETENTION_DAYS=14
